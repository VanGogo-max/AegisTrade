!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AegisTrade Dashboard</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #0a0a0f;
    color: #e0e0e0;
    font-family: 'Courier New', monospace;
    min-height: 100vh;
    padding: 20px;
  }

  .header {
    text-align: center;
    padding: 20px 0 30px;
    border-bottom: 1px solid #1a1a2e;
    margin-bottom: 30px;
  }

  .header h1 {
    font-size: 2rem;
    letter-spacing: 4px;
    color: #00d4ff;
    text-transform: uppercase;
  }

  .header p {
    color: #555;
    margin-top: 5px;
    font-size: 0.8rem;
    letter-spacing: 2px;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    max-width: 800px;
    margin: 0 auto;
  }

  .card {
    background: #0f0f1a;
    border: 1px solid #1a1a2e;
    border-radius: 8px;
    padding: 20px;
  }

  .card.full { grid-column: 1 / -1; }

  .card-title {
    font-size: 0.7rem;
    letter-spacing: 2px;
    color: #555;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .card-value {
    font-size: 1.8rem;
    font-weight: bold;
    color: #00d4ff;
  }

  .card-value.green { color: #00ff88; }
  .card-value.red   { color: #ff4466; }
  .card-value.yellow { color: #ffcc00; }

  /* Mode toggle */
  .toggle-wrap {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 8px;
  }

  .toggle-label {
    font-size: 0.85rem;
    color: #888;
  }

  .toggle {
    position: relative;
    width: 60px;
    height: 30px;
  }

  .toggle input { opacity: 0; width: 0; height: 0; }

  .slider {
    position: absolute;
    cursor: pointer;
    inset: 0;
    background: #1a1a2e;
    border-radius: 30px;
    transition: 0.3s;
    border: 1px solid #333;
  }

  .slider:before {
    content: "";
    position: absolute;
    width: 22px;
    height: 22px;
    left: 4px;
    top: 3px;
    background: #555;
    border-radius: 50%;
    transition: 0.3s;
  }

  input:checked + .slider { background: #1a3a1a; border-color: #00ff88; }
  input:checked + .slider:before {
    transform: translateX(30px);
    background: #00ff88;
  }

  .mode-badge {
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 0.75rem;
    letter-spacing: 1px;
    font-weight: bold;
  }

  .mode-badge.dry  { background: #1a1a2e; color: #ffcc00; border: 1px solid #ffcc00; }
  .mode-badge.live { background: #1a3a1a; color: #00ff88; border: 1px solid #00ff88; }

  /* Exchange selector */
  select {
    width: 100%;
    background: #1a1a2e;
    color: #e0e0e0;
    border: 1px solid #333;
    border-radius: 6px;
    padding: 10px;
    font-family: 'Courier New', monospace;
    font-size: 0.9rem;
    margin-top: 8px;
    cursor: pointer;
    outline: none;
  }

  select:focus { border-color: #00d4ff; }

  /* Status dot */
  .status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #00ff88;
    margin-right: 8px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .signal-hold  { color: #888; }
  .signal-buy   { color: #00ff88; }
  .signal-sell  { color: #ff4466; }

  .footer {
    text-align: center;
    margin-top: 30px;
    color: #333;
    font-size: 0.7rem;
    letter-spacing: 2px;
  }
</style>
</head>
<body>

<div class="header">
  <h1>⬡ AegisTrade</h1>
  <p>Global Risk & Strategy Manager</p>
</div>

<div class="grid">

  <!-- Price -->
  <div class="card">
    <div class="card-title">Price</div>
    <div class="card-value" id="price">—</div>
  </div>

  <!-- Signal -->
  <div class="card">
    <div class="card-title">Signal</div>
    <div class="card-value signal-hold" id="signal">—</div>
  </div>

  <!-- Position -->
  <div class="card">
    <div class="card-title">Position</div>
    <div class="card-value" id="position">flat</div>
  </div>

  <!-- PnL -->
  <div class="card">
    <div class="card-title">PnL</div>
    <div class="card-value" id="pnl">—</div>
  </div>

  <!-- Regime -->
  <div class="card">
    <div class="card-title">Regime</div>
    <div class="card-value yellow" id="regime">—</div>
  </div>

  <!-- Action -->
  <div class="card">
    <div class="card-title">
      <span class="status-dot"></span>Action
    </div>
    <div class="card-value" id="action">—</div>
  </div>

  <!-- Mode toggle -->
  <div class="card full">
    <div class="card-title">Trading Mode</div>
    <div class="toggle-wrap">
      <span class="toggle-label">DRY RUN</span>
      <label class="toggle">
        <input type="checkbox" id="modeToggle" onchange="toggleMode()">
        <span class="slider"></span>
      </label>
      <span class="toggle-label">LIVE</span>
      <span class="mode-badge dry" id="modeBadge">DRY RUN</span>
    </div>
  </div>

  <!-- Exchange selector -->
  <div class="card full">
    <div class="card-title">Exchange</div>
    <select id="exchangeSelect" onchange="setExchange()">
      <option value="hyperliquid">Hyperliquid</option>
      <option value="gmx">GMX</option>
      <option value="dydx">dYdX</option>
      <option value="vertex">Vertex</option>
      <option value="apex">Apex</option>
      <option value="kwenta">Kwenta</option>
    </select>
  </div>

</div>

<div class="footer">AEGISTRADE v1.0 — DRY RUN MODE</div>

<script>
  const API = "http://localhost:8000";

  async function fetchStatus() {
    try {
      const r = await fetch(`${API}/api/status`);
      const d = await r.json();

      document.getElementById("price").textContent =
        d.price ? `$${Number(d.price).toLocaleString()}` : "—";

      const signalEl = document.getElementById("signal");
      signalEl.textContent = d.signal || "—";
      signalEl.className = "card-value signal-" + (d.signal || "hold").toLowerCase();

      document.getElementById("regime").textContent = d.regime || "—";
      document.getElementById("action").textContent = d.action || "—";

      const pos = d.position;
      document.getElementById("position").textContent =
        pos && pos > 0 ? `$${pos.toLocaleString()}` : "flat";

      document.getElementById("pnl").textContent = d.pnl || "—";

      const toggle = document.getElementById("modeToggle");
      const badge  = document.getElementById("modeBadge");
      const isLive = !d.dry_run;
      toggle.checked = isLive;
      badge.textContent = isLive ? "LIVE" : "DRY RUN";
      badge.className = "mode-badge " + (isLive ? "live" : "dry");

      const sel = document.getElementById("exchangeSelect");
      if (d.exchange) sel.value = d.exchange;

    } catch(e) {
      console.log("API offline");
    }
  }

  async function toggleMode() {
    const isLive = document.getElementById("modeToggle").checked;
    await fetch(`${API}/api/mode`, {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({dry_run: !isLive}),
    });
    fetchStatus();
  }

  async function setExchange() {
    const exchange = document.getElementById("exchangeSelect").value;
    await fetch(`${API}/api/exchange`, {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({exchange}),
    });
  }

  fetchStatus();
  setInterval(fetchStatus, 3000);
