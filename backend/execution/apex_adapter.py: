import time
from decimal import Decimal

import aiohttp
from loguru import logger

from backend.execution.execution_engine import (
    BaseExecutionAdapter,
    ExecutionRequest,
    ExecutionResult,
    OrderSide,
    OrderType,
)
from backend.config.config import Config


class ApexAdapter(BaseExecutionAdapter):

    BASE_URL = "https://pro.apex.exchange/api/v1"

    MARKET_IDS = {
        "BTC": "BTC-USDC",
        "ETH": "ETH-USDC",
        "SOL": "SOL-USDC",
        "ARB": "ARB-USDC",
    }

    def __init__(self):
        self.private_key = Config.DEX_PRIVATE_KEY
        self.wallet = Config.DEX_WALLET_ADDRESS

    async def place_order(self, request: ExecutionRequest) -> ExecutionResult:
        if Config.DRY_RUN:
            logger.debug(f"[DRY RUN Apex] {request.side} {request.quantity} {request.symbol}")
            return ExecutionResult(
                exchange="apex",
                symbol=request.symbol,
                order_id=f"apex-dry-{int(time.time())}",
                status="filled",
                filled_quantity=request.quantity,
                avg_price=request.price or Decimal("0"),
                raw_response={},
            )

        market = self._market_id(request.symbol)
        side = "BUY" if request.side == OrderSide.BUY else "SELL"

        payload = {
            "symbol": market,
            "side": side,
            "type": "MARKET" if request.order_type == OrderType.MARKET else "LIMIT",
            "size": str(request.quantity),
            "price": str(request.price or "0"),
            "clientOrderId": str(int(time.time())),
            "signature": self.private_key,
            "accountAddress": self.wallet,
        }

        async with aiohttp.ClientSession() as session:
            async with session.post(
                f"{self.BASE_URL}/order",
                json=payload,
                headers={"Content-Type": "application/json"},
            ) as resp:
                data = await resp.json()
                logger.debug(f"Apex response: {data}")

                return ExecutionResult(
                    exchange="apex",
                    symbol=request.symbol,
                    order_id=str(data.get("id", f"apex-{int(time.time())}")),
                    status=data.get("status", "submitted"),
                    filled_quantity=request.quantity,
                    avg_price=request.price,
                    raw_response=data,
                )

    async def cancel_order(self, symbol: str, order_id: str) -> bool:
        if Config.DRY_RUN:
            logger.debug(f"[DRY RUN Apex] cancel {order_id}")
            return True

        async with aiohttp.ClientSession() as session:
            async with session.delete(
                f"{self.BASE_URL}/order",
                json={"id": order_id, "accountAddress": self.wallet},
            ) as resp:
                data = await resp.json()
                return data.get("status") in ("CANCELED", "ok")

    def _market_id(self, symbol: str) -> str:
        base = symbol.split("-")[0].upper()
        market = self.MARKET_IDS.get(base)
        if not market:
            raise ValueError(f"Apex: unknown market for {symbol}")
        return market
