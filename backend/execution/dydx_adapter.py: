import time
from decimal import Decimal

import aiohttp
from loguru import logger

from backend.execution.execution_engine import (
    BaseExecutionAdapter,
    ExecutionRequest,
    ExecutionResult,
    OrderSide,
    OrderType,
)
from backend.config.config import Config


class DydxAdapter(BaseExecutionAdapter):

    BASE_URL = "https://indexer.dydx.trade/v4"

    MARKET_IDS = {
        "BTC": "BTC-USD",
        "ETH": "ETH-USD",
        "SOL": "SOL-USD",
        "ARB": "ARB-USD",
    }

    def __init__(self):
        self.private_key = Config.DEX_PRIVATE_KEY
        self.wallet = Config.DEX_WALLET_ADDRESS

    async def place_order(self, request: ExecutionRequest) -> ExecutionResult:
        if Config.DRY_RUN:
            logger.debug(f"[DRY RUN dYdX] {request.side} {request.quantity} {request.symbol}")
            return ExecutionResult(
                exchange="dydx",
                symbol=request.symbol,
                order_id=f"dydx-dry-{int(time.time())}",
                status="filled",
                filled_quantity=request.quantity,
                avg_price=request.price or Decimal("0"),
                raw_response={},
            )

        market = self._market_id(request.symbol)
        side = "BUY" if request.side == OrderSide.BUY else "SELL"
        order_type = "MARKET" if request.order_type == OrderType.MARKET else "LIMIT"

        payload = {
            "market": market,
            "side": side,
            "type": order_type,
            "size": str(request.quantity),
            "price": str(request.price or "0"),
            "timeInForce": "GTT",
            "postOnly": False,
            "reduceOnly": False,
            "clientId": str(int(time.time())),
            "goodTilBlockTime": int(time.time()) + 300,
        }

        async with aiohttp.ClientSession() as session:
            async with session.post(
                f"{self.BASE_URL}/orders",
                json=payload,
                headers={
                    "Content-Type": "application/json",
                    "Authorization": f"Bearer {self.private_key}",
                },
            ) as resp:
                data = await resp.json()
                logger.debug(f"dYdX response: {data}")

                return ExecutionResult(
                    exchange="dydx",
                    symbol=request.symbol,
                    order_id=str(data.get("id", f"dydx-{int(time.time())}")),
                    status=data.get("status", "submitted"),
                    filled_quantity=request.quantity,
                    avg_price=request.price,
                    raw_response=data,
                )

    async def cancel_order(self, symbol: str, order_id: str) -> bool:
        if Config.DRY_RUN:
            logger.debug(f"[DRY RUN dYdX] cancel {order_id}")
            return True

        async with aiohttp.ClientSession() as session:
            async with session.delete(
                f"{self.BASE_URL}/orders/{order_id}",
                headers={"Authorization": f"Bearer {self.private_key}"},
            ) as resp:
                data = await resp.json()
                return data.get("status") in ("CANCELED", "ok")

    def _market_id(self, symbol: str) -> str:
        base = symbol.split("-")[0].upper()
        market = self.MARKET_IDS.get(base)
        if not market:
            raise ValueError(f"dYdX: unknown market for {symbol}")
        return market
