import time
from decimal import Decimal

import aiohttp
from loguru import logger

from backend.execution.execution_engine import (
    BaseExecutionAdapter,
    ExecutionRequest,
    ExecutionResult,
    OrderSide,
    OrderType,
)
from backend.config.config import Config


class VertexAdapter(BaseExecutionAdapter):

    BASE_URL = "https://gateway.prod.vertexprotocol.com/v1"

    PRODUCT_IDS = {
        "BTC": 2,
        "ETH": 4,
        "SOL": 6,
        "ARB": 8,
    }

    def __init__(self):
        self.private_key = Config.DEX_PRIVATE_KEY
        self.wallet = Config.DEX_WALLET_ADDRESS

    async def place_order(self, request: ExecutionRequest) -> ExecutionResult:
        if Config.DRY_RUN:
            logger.debug(f"[DRY RUN Vertex] {request.side} {request.quantity} {request.symbol}")
            return ExecutionResult(
                exchange="vertex",
                symbol=request.symbol,
                order_id=f"vertex-dry-{int(time.time())}",
                status="filled",
                filled_quantity=request.quantity,
                avg_price=request.price or Decimal("0"),
                raw_response={},
            )

        product_id = self._product_id(request.symbol)
        is_buy = request.side == OrderSide.BUY

        payload = {
            "place_order": {
                "product_id": product_id,
                "order": {
                    "sender": self.wallet,
                    "priceX18": str(int((request.price or Decimal("0")) * Decimal("1e18"))),
                    "amount": str(int(request.quantity * (1 if is_buy else -1) * Decimal("1e18"))),
                    "expiration": int(time.time()) + 300,
                    "nonce": int(time.time() * 1000),
                },
                "signature": self.private_key,
            }
        }

        async with aiohttp.ClientSession() as session:
            async with session.post(
                f"{self.BASE_URL}/execute",
                json=payload,
            ) as resp:
                data = await resp.json()
                logger.debug(f"Vertex response: {data}")

                return ExecutionResult(
                    exchange="vertex",
                    symbol=request.symbol,
                    order_id=str(data.get("digest", f"vertex-{int(time.time())}")),
                    status=data.get("status", "submitted"),
                    filled_quantity=request.quantity,
                    avg_price=request.price,
                    raw_response=data,
                )

    async def cancel_order(self, symbol: str, order_id: str) -> bool:
        if Config.DRY_RUN:
            logger.debug(f"[DRY RUN Vertex] cancel {order_id}")
            return True

        payload = {
            "cancel_orders": {
                "tx": {
                    "sender": self.wallet,
                    "productIds": [self._product_id(symbol)],
                    "digests": [order_id],
                    "nonce": int(time.time() * 1000),
                },
                "signature": self.private_key,
            }
        }

        async with aiohttp.ClientSession() as session:
            async with session.post(
                f"{self.BASE_URL}/execute",
                json=payload,
            ) as resp:
                data = await resp.json()
                return data.get("status") == "success"

    def _product_id(self, symbol: str) -> int:
        base = symbol.split("-")[0].upper()
        pid = self.PRODUCT_IDS.get(base)
        if not pid:
            raise ValueError(f"Vertex: unknown product for {symbol}")
        return pid
