################################################
# ГЛОБАЛНИ НАСТРОЙКИ
################################################

APP_ENV=production
APP_NAME=AegisTrade
LOG_LEVEL=INFO
TIMEZONE=UTC

################################################
# DEX WALLET
################################################

DEX_PRIVATE_KEY=
DEX_WALLET_ADDRESS=

################################################
# RPC ENDPOINTS
################################################

ETH_RPC_URL=
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
POLYGON_RPC_URL=https://polygon-rpc.com

################################################
# SUPPORTED DEX (primary execution)
################################################

PRIMARY_DEX=hyperliquid

################################################
# DEX CONFIG
################################################

HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
DYDX_API_URL=
GMX_ROUTER_ADDRESS=
APEX_API_URL=
KWENTA_ROUTER_ADDRESS=
VERTEX_API_URL=

################################################
# RISK MANAGEMENT
################################################

MAX_RISK_PER_TRADE=0.01
MAX_DRAWDOWN=0.05
MAX_OPEN_POSITIONS=5
SLIPPAGE_TOLERANCE=0.003

################################################
# EXECUTION SETTINGS
################################################

DEFAULT_LEVERAGE=3
MAX_GAS_GWEI=120
MEV_PROTECTION=true
FLASHBOTS_RELAY=https://relay.flashbots.net

################################################
# PORTFOLIO
################################################

PORTFOLIO_VOLATILITY_TARGET=0.15
CORRELATION_THRESHOLD=0.8
DRAWDOWN_LOCK_THRESHOLD=0.08

################################################
# DATABASE
################################################

DB_TYPE=sqlite
DB_PATH=data/trading.db

################################################
# MONITORING
################################################

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9100

################################################
# TELEGRAM ALERTS (optional)
################################################

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

################################################
# SECURITY
################################################

ENABLE_ENCRYPTION=true
KEY_DERIVATION_SALT=
